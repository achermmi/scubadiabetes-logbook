<?xml version="1.0"?>
<ruleset name="ScubaDiabetes Logbook">

    <rule ref="WordPress"/>

    <file>includes</file>
    <file>src</file>
    <file>scubadiabetes-logbook.php</file>

    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>tools/*</exclude-pattern>
    <exclude-pattern>tests/*</exclude-pattern>

    <!-- Doc comment style: not enforced for existing codebase -->
    <rule ref="Squiz.Commenting.ClassComment"><severity>0</severity></rule>
    <rule ref="Squiz.Commenting.FunctionComment"><severity>0</severity></rule>
    <rule ref="Squiz.Commenting.VariableComment"><severity>0</severity></rule>
    <rule ref="Squiz.Commenting.InlineComment"><severity>0</severity></rule>
    <rule ref="Generic.Commenting.DocComment"><severity>0</severity></rule>

    <!-- DB: table name interpolation via $wpdb->prepare() is safe with phpcs:ignore -->
    <rule ref="WordPress.DB.DirectDatabaseQuery"><severity>0</severity></rule>
    <rule ref="WordPress.DB.PreparedSQL"><severity>0</severity></rule>

    <!-- Discouraged PHP functions (base64, etc.) used intentionally -->
    <rule ref="WordPress.PHP.DiscouragedPHPFunctions"><severity>0</severity></rule>

    <!-- Custom capabilities registered in class-sd-roles.php -->
    <rule ref="WordPress.WP.Capabilities"><severity>0</severity></rule>

    <!-- Elvis/short ternary operator: used intentionally in existing code -->
    <rule ref="Universal.Operators.DisallowShortTernary"><severity>0</severity></rule>

    <!-- Input sanitization and nonce: existing AJAX handlers use check_ajax_referer -->
    <rule ref="WordPress.Security.ValidatedSanitizedInput"><severity>0</severity></rule>
    <rule ref="WordPress.Security.NonceVerification"><severity>0</severity></rule>

    <!-- Block comment format and output escaping: existing templates -->
    <rule ref="Squiz.Commenting.BlockComment"><severity>0</severity></rule>
    <rule ref="WordPress.Security.EscapeOutput"><severity>0</severity></rule>

    <!-- Translators comment: handled where needed -->
    <rule ref="WordPress.WP.I18n"><severity>0</severity></rule>

    <!-- Duplicate array key: legacy code, not a security issue -->
    <rule ref="Universal.Arrays.DuplicateArrayKey"><severity>0</severity></rule>

    <!-- File comment @package tag: not enforced -->
    <rule ref="Squiz.Commenting.FileComment"><severity>0</severity></rule>

    <!-- Commented-out code: allowed in this codebase -->
    <rule ref="Squiz.PHP.CommentedOutCode"><severity>0</severity></rule>

    <!-- Unused parameters: common in WordPress hook callbacks -->
    <rule ref="Generic.CodeAnalysis.UnusedFunctionParameter"><severity>0</severity></rule>

    <!-- File naming: src/Plugin.php uses PSR-4 naming, not WP naming convention -->
    <rule ref="WordPress.Files.FileName"><severity>0</severity></rule>

    <!-- Line endings: Windows CRLF vs Linux LF - handled by git autocrlf -->
    <rule ref="Generic.Files.LineEndings"><severity>0</severity></rule>

</ruleset>
